# OS
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Node (in case any tooling is added later)
node_modules/

# Python — bootstrap.py and hook scripts run via `python3` directly, not
# imported, but a stray `py_compile` or test import will leave these behind.
__pycache__/
*.pyc
*.pyo

# Dedicated venv bootstrap.py builds for global installs / PEP 668 hosts
# (MANAGED_VENV_DIR). Machine-specific; never committed.
.venv/

# Local config / secrets
.env
.env.local
.env.*.local

# Logs
*.log
